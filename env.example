# Urbex Frontend Environment Variables
# ===================================
# Copy this file to .env.local and fill in your values

# API Externa Configuration
# ========================
NEXT_PUBLIC_API_BASE_URL=https://api.urbex.com.co
NEXT_PUBLIC_API_KEY=your_frontend_api_key_here

# AWS Cognito Configuration
# =========================
NEXT_PUBLIC_AWS_REGION=us-east-2
NEXT_PUBLIC_AWS_USER_POOL_ID=us-east-2_Fpda5LMX0
NEXT_PUBLIC_AWS_POOL_CLIENT_ID=your_cognito_client_id_here

# Application Configuration
# ========================
NEXT_PUBLIC_APP_NAME=Urbex
NEXT_PUBLIC_APP_URL=https://urbex.com.co

# Maps API Configuration
# ======================
# Google Maps API Key for Street View and Satellite maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# Mapbox Access Token for 3D maps
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_access_token_here

# Development Configuration
# ========================
# Uncomment for local development
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Staging Configuration
# ====================
# Uncomment for staging environment
# NEXT_PUBLIC_API_BASE_URL=https://staging-api.urbex.com.co
# NEXT_PUBLIC_APP_URL=https://staging.urbex.com.co

# Production Configuration
# =======================
# Uncomment for production environment
# NEXT_PUBLIC_API_BASE_URL=https://api.urbex.com.co
# NEXT_PUBLIC_APP_URL=https://urbex.com.co

# Server-Side Secrets (NOT for frontend - only for build/deployment scripts)
# ===========================================================================
# ⚠️  SECURITY WARNING: These should NEVER be in frontend code
# These are only used by deployment scripts and server-side operations
# They will NOT be included in the generated public/env.js file

# AWS Credentials (for S3 deployment scripts only)
# AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS_REGION=us-east-2
# S3_BUCKET_NAME=your-bucket-name
# CF_DISTRIBUTION_ID=your-cloudfront-distribution-id

# API Keys (server-side only - not exposed to frontend)
# API_KEY=your_backend_api_key
# ADMIN_API_KEY=your_admin_api_key
# PUBLIC_API_KEY=your_public_api_key

# Mailgun (for email functionality - server-side only)
# MAILGUN_API_KEY=your_mailgun_api_key
# MAILGUN_DOMAIN=your_mailgun_domain
# CONTACT_EMAIL=contact@urbex.com.co 