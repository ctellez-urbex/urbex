# Urbex Frontend Environment Variables
# ===================================
# Copy this file to .env.local and fill in your values

# API Externa Configuration
# ========================
NEXT_PUBLIC_API_BASE_URL=https://api.urbex.com.co
NEXT_PUBLIC_API_KEY=your_frontend_api_key_here

# AWS Cognito Configuration
# =========================
NEXT_PUBLIC_AWS_REGION=us-east-2
NEXT_PUBLIC_AWS_USER_POOL_ID=us-east-2_Fpda5LMX0
NEXT_PUBLIC_AWS_POOL_CLIENT_ID=your_cognito_client_id_here

# Application Configuration
# ========================
NEXT_PUBLIC_APP_NAME=Urbex
NEXT_PUBLIC_APP_URL=https://urbex.com.co

# Maps API Configuration
# ======================
# Google Maps API Key for Street View and Satellite maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# Mapbox Access Token for 3D maps
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_access_token_here

# Development Configuration
# ========================
# Uncomment for local development
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Staging Configuration
# ====================
# Uncomment for staging environment
# NEXT_PUBLIC_API_BASE_URL=https://staging-api.urbex.com.co
# NEXT_PUBLIC_APP_URL=https://staging.urbex.com.co

# Production Configuration
# =======================
# Uncomment for production environment
# NEXT_PUBLIC_API_BASE_URL=https://api.urbex.com.co
# NEXT_PUBLIC_APP_URL=https://urbex.com.co 