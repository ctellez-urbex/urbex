    "lucide-react": "^0.511.0",
    "mime-types": "^3.0.1",
    "next": "^15.0.0",
    "next-themes": "^0.4.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.34.2",
